# ══════════════════════════════════════════════════════════════════════════════
# ProzessPilot — Webapp Vite Environment Variables
# Kopiere diese Datei als .env (lokal) oder übergib die Werte als Docker Build-Args
# Alle Variablen mit Prefix VITE_ sind zur Build-Zeit eingebettet (kein Runtime-Secret)
# ══════════════════════════════════════════════════════════════════════════════

# Backend-API-URL für Links und API-Calls aus der Webapp
# Dev-Default: http://localhost:3000
# Production:  https://api.yourserver.de
VITE_API_URL=http://localhost:3000

# n8n-URL für Links in der SettingsPage
# Dev-Default: http://localhost:5678
# Production:  https://n8n.yourserver.de
VITE_N8N_URL=http://localhost:5678
