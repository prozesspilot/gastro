              "value": "application/json"
            },
            {
              "name": "x-customer-id",
              "value": "={{$('Code: Normalize Payload').item.json.customer_id}}"
            },
            {
              "name": "x-trace-id",
              "value": "={{$('Code: Normalize Payload').item.json.trace_id}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"receipt_id\":\"{{$('Code: Normalize Payload').item.json.receipt_id}}\",\"customer_id\":\"{{$('Code: Normalize Payload').item.json.customer_id}}\"}",
        "options": {
