    {
      "id": "n16a-classify-error",
      "name": "Function: Classify Stage Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2360,
        520
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Mappt Module + Fehlercode auf einen errorType, den der WF-ERROR-HANDLER\n// klassifizieren kann. Wird im Error-Branch des Master-Workflows aufgerufen.\nconst sub = $json || {};\nconst module = sub.module || ($('Split: Steps').item.json.module || 'master');\nconst errorCode = (sub.error && sub.error.code) || '';\nconst errorMsg  = (sub.error && sub.error.message) || 'sub-workflow failed';\n\nlet errorType = 'WEBHOOK_FAILED';\nswitch (module) {\n  case 'M01': errorType = 'OCR_FAILED';      break;\n  case 'M03': errorType = 'CATEGORY_FAILED'; break;\n  case 'M02': errorType = 'ARCHIVE_FAILED';  break;\n  case 'M05':\n  case 'M06':\n  case 'M07': errorType = 'EXPORT_FAILED';   break;\n  default:    errorType = 'PIPELINE_FAILED';\n}\nif (/timeout/i.test(errorMsg) || /timeout/i.test(errorCode)) errorType = 'TIMEOUT';\nif (errorCode === 'INVALID_STATUS') errorType = 'PIPELINE_FAILED';\n\nreturn [{\n  json: {\n    receiptId:  $('HTTP: Backend create_receipt').item.json.data.receipt_id,\n    customerId: $('Trigger: Sub-Workflow').item.json.customer_id,\n    traceId:    $('Trigger: Sub-Workflow').item.json.trace_id,\n    stage:      module,\n    errorType:  errorType,\n    error:      errorMsg\n  }\n}];"
      }
