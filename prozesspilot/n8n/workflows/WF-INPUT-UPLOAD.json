    {
      "id": "n1-webhook",
      "name": "Trigger: Webhook Upload",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "path": "receipt-received",
        "httpMethod": "POST",
        "responseMode": "onReceived",
        "responseData": "firstEntryJson",
        "options": {}
      },
      "webhookId": "receipt-received-webhook"
    },
    {
      "id": "n2-normalize",
      "name": "Code: Normalize Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Normalisiert den Webhook-Payload vom Backend.\n// Unterstuetzt sowohl snake_case als auch camelCase Felder.\nconst body = $json.body ?? $json;\n\nconst customerId = body.customer_id ?? body.customerId ?? '';\nconst receiptId  = body.receipt_id  ?? body.receiptId  ?? '';\nconst tenantId   = body.tenant_id   ?? body.tenantId   ?? '';\nconst traceId    = body.trace_id    ?? body.traceId    ?? `upload-${Date.now()}`;\n\nreturn [{\n  json: {\n    customer_id:   customerId,\n    receipt_id:    receiptId,\n    tenant_id:     tenantId,\n    trace_id:      traceId,\n    storage_key:   body.storage_key   ?? '',\n    original_name: body.original_name ?? '',\n    mime_type:     body.mime_type     ?? 'application/octet-stream',\n    size_bytes:    body.size_bytes    ?? 0\n  }\n}];"
      }
    },
    {
      "id": "n3-get-profile",
      "name": "HTTP: get_profile",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "={{$env.BACKEND_URL}}/api/v1/internal/profile/{{$json.customer_id}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-customer-id",
              "value": "={{$json.customer_id}}"
            },
            {
              "name": "x-trace-id",
              "value": "={{$json.trace_id}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "continueOnFail": false
    },
    {
