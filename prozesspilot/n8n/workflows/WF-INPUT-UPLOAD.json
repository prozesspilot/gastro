    {
      "id": "n5b-build-subwf-input",
      "name": "Code: Build Sub-WF Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1380,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "\n// Baut das Input-Objekt das alle Sub-WF (M01, M02, ...) erwarten:\n//   { trace_id, receipt, customer_profile, idempotency_key, module }\nconst normalize   = $('Code: Normalize Payload').item.json;\nconst profileResp = $('HTTP: get_profile').item.json;\nconst step        = $json;\n\nconst receiptId  = normalize.receipt_id  || '';\nconst customerId = normalize.customer_id || '';\nconst tenantId   = normalize.tenant_id   || '';\nconst traceId    = normalize.trace_id    || `upload-${Date.now()}`;\nconst storageKey = normalize.storage_key || '';\n\n// Raw profile from DB (flat integrations keys)\nconst profile = (profileResp.data && profileResp.data.profile) || profileResp.data || {};\n\n// Normalize integrations: bridge flat DB format -> nested OCR format\n// DB stores: integrations.ocr_provider, integrations.ocr_api_key\n// extract handler expects: integrations.ocr.provider, integrations.ocr.config\nconst intgRaw     = profile.integrations || {};\nconst ocrProvider = intgRaw.ocr_provider || 'google_vision';\nconst ocrApiKey   = intgRaw.ocr_api_key  || null;\n\nconst intgNormalized = { ...intgRaw };\ndelete intgNormalized.ocr_provider;\ndelete intgNormalized.ocr_api_key;\nintgNormalized.ocr = {\n  provider: ocrProvider,\n  config:   ocrApiKey ? { api_key: ocrApiKey } : {}\n};\n\nconst customer_profile = {\n  customer_id:     customerId,\n  modules_enabled: profile.modules_enabled || [],\n  integrations:    intgNormalized,\n  routing:         profile.routing || {},\n  custom:          profile.custom  || {},\n};\n\n// Receipt object in the format M01..M07 expect\nconst receipt = {\n  receipt_id:    receiptId,\n  customer_id:   customerId,\n  tenant_id:     tenantId,\n  status:        'received',\n  source:        'upload',\n  storage_key:   storageKey,\n  file: {\n    storage_key:   storageKey,\n    original_name: normalize.original_name || '',\n    mime_type:     normalize.mime_type     || 'application/octet-stream',\n    size_bytes:    normalize.size_bytes    || 0\n  },\n  user_caption: ''\n};\n\nreturn [{\n  json: {\n    trace_id:        traceId,\n    receipt,\n    customer_profile,\n    idempotency_key:  `ik_${step.module}_${receiptId}`,\n    module:           step.module\n  }\n}];\n"
      }
    },
