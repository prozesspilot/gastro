{
  "name": "prozesspilot-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../.env src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node --env-file-if-exists=../.env dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "migrate": "tsx --env-file-if-exists=../.env src/core/db/migrate.ts",
    "migrate:prod": "node dist/core/db/migrate.js",
    "seed:dev": "tsx --env-file-if-exists=../.env src/core/db/seed-dev.ts",
    "bootstrap-admin": "tsx --env-file-if-exists=../.env scripts/bootstrap-admin.ts",
    "bootstrap-lexware-token": "tsx --env-file-if-exists=../.env scripts/bootstrap-lexware-token.ts",
    "test:integration": "TEST_DATABASE_URL=postgresql://pp:pp@localhost:5432/pp_test vitest run src/__tests__/integration"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@google-cloud/vision": "^4.3.0",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "@types/archiver": "^7.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "archiver": "^8.0.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.78.1",
    "fastify": "^4.28.0",
    "google-auth-library": "^9.14.0",
    "googleapis": "^144.0.0",
    "imapflow": "^1.4.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mindee": "^5.3.1",
    "nodemailer": "^8.0.7",
    "otpauth": "^9.5.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0",
    "pino": "^9.2.0",
    "prom-client": "^15.1.3",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.35.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
