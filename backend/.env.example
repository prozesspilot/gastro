# ProzessPilot Backend — Umgebungsvariablen
# Kopiere diese Datei nach .env und setze echte Werte

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000
LOG_LEVEL=info                # trace | debug | info | warn | error | silent

# ── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://pp:pp@localhost:5432/prozesspilot
REDIS_URL=redis://localhost:6379

# ── Objekt-Speicher (MinIO / S3) ─────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=pp
MINIO_SECRET_KEY=pp-secret          # ACHTUNG: In Produktion starkes Passwort!
MINIO_BUCKET=prozesspilot-raw
STORAGE_RAW_BUCKET=prozesspilot-raw

# ── Auth ─────────────────────────────────────────────────────────────────────
PP_HMAC_SECRET=                     # Mindestens 32 Zeichen, hex-kodiert
PP_HMAC_TIMESTAMP_SKEW=300          # Sekunden Toleranz
PP_AUTH_DISABLED=1                  # NIEMALS in Produktion auf 1 setzen!

# ── M14: Discord OAuth 2.0 (Mitarbeiter-Login) ───────────────────────────────
DISCORD_CLIENT_ID=                  # Discord Developer Portal → OAuth2
DISCORD_CLIENT_SECRET=              # Discord Developer Portal → OAuth2
# WICHTIG: muss EXAKT mit dem Eintrag im Discord Developer Portal (OAuth2 →
# Redirects) übereinstimmen UND auf den Backend-Callback-Pfad /api/v1/... zeigen.
# Der Callback liegt unter /api/v1/auth/discord/callback (Route + Prefix, via
# nginx /api/-Proxy). Fehlt das /api/v1, landet Discord auf dem SPA-Fallback →
# stiller Login-Loop. Auf admin.* (nicht api.*), damit das Cookie same-origin
# zur Webapp gesetzt wird.
DISCORD_REDIRECT_URI=https://admin.prozesspilot.net/api/v1/auth/discord/callback
DISCORD_GUILD_ID=                   # Nur Mitglieder dieses Servers dürfen einloggen
DISCORD_BOT_TOKEN=                  # Für Guild-Membership-Check
DISCORD_ROLE_ID_GF=                 # Optional: Discord-Rolle → Geschäftsführer-Rolle

# ── PostgreSQL PGCrypto ───────────────────────────────────────────────────────
PP_PGCRYPTO_KEY=                    # Verschluesselungsschluessel fuer PII-Felder

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=            # n8n Admin-Passwort
N8N_WEBHOOK_SECRET=                 # HMAC-Secret fuer eingehende n8n-Webhooks

# ── Claude API (M03/M04 Kategorisierung) ─────────────────────────────────────
CLAUDE_API_KEY=                     # Anthropic API Key
CLAUDE_MODEL=claude-sonnet-4-6

# ── Google Vision API (M03 OCR) ──────────────────────────────────────────────
GOOGLE_VISION_KEY_FILE=             # Pfad zur JSON-Service-Account-Datei
OCR_TIMEOUT_MS=15000

# ── Mindee API (M03 OCR – Pro-Paket) ─────────────────────────────────────────
MINDEE_API_KEY=                     # Mindee API-Key fuer InvoiceV4 (Phase 3)

# ── Monitoring (optional) ─────────────────────────────────────────────────────
LOKI_URL=                           # Grafana Loki URL fuer Logs (optional)

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=                         # https://xxx@oNNN.ingest.sentry.io/NNN — leer = deaktiviert
APP_VERSION=1.0.0                   # Release-Tag fuer Sentry (z.B. Git-SHA oder SemVer)

# ── WhatsApp / Meta (M10) ─────────────────────────────────────────────────────
WHATSAPP_APP_SECRET=                # Meta App Secret fuer X-Hub-Signature Verifizierung
WHATSAPP_VERIFY_TOKEN=              # Meta Webhook Verify-Token
WHATSAPP_GRAPH_API_VERSION=v19.0

# ── Google OAuth (M07 Sheets / M02 Drive) ────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=             # Google OAuth2 Client ID
GOOGLE_OAUTH_CLIENT_SECRET=         # Google OAuth2 Client Secret

# ── M15: SumUp POS-Connector OAuth ───────────────────────────────────────────
# App registrieren unter: https://developer.sumup.com
# Scopes: transactions.history.read user.profile_readonly
# Redirect-URI muss exakt mit Developer Portal übereinstimmen.
SUMUP_CLIENT_ID=                    # SumUp OAuth2 Client ID
SUMUP_CLIENT_SECRET=                # SumUp OAuth2 Client Secret
SUMUP_REDIRECT_URI=https://api.prozesspilot.net/api/v1/m15/oauth/sumup/callback
SUMUP_API_BASE_URL=https://api.sumup.com

# ── Backup (nur fuer Backup-Skripte, nicht fuer den Server selbst) ─────────────
# BACKUP_DIR=/backups/postgres
# RETENTION_DAYS=90
# AWS_BACKUP_BUCKET=prozesspilot-backup
# PP_S3_BUCKET=prozesspilot-receipts
# PP_S3_ENDPOINT=http://localhost:9000  (leer = AWS S3)
