    {
      "id": "n6b-build-payload",
      "name": "Function: Build Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1510,
        400
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "\n// Assembles the unified payload for all sub-workflows (M01, M02, M03, \u2026).\n// Bridges the gap between the flat DB integrations format and what M01/extract expects.\n\nconst receiptRaw  = $('HTTP: Reload Receipt').item.json.data || {};\nconst profileResp = $('HTTP: Backend get_profile').item.json.data || {};\nconst profile     = profileResp.profile || profileResp || {};\nconst trigger     = $('Trigger: Sub-Workflow').item.json;\nconst step        = $('Split: Steps').item.json;\n\n// Normalize receipt (API returns 'id', sub-workflows expect 'receipt_id')\nconst receipt = {\n  receipt_id:    receiptRaw.id || receiptRaw.receipt_id,\n  customer_id:   receiptRaw.customer_id || trigger.customer_id,\n  status:        receiptRaw.status,\n  storage_key:   receiptRaw.storage_key,\n  original_name: receiptRaw.original_name,\n  mime_type:     receiptRaw.mime_type,\n  file_size_bytes: receiptRaw.file_size_bytes,\n  source:        receiptRaw.source || 'upload',\n  file: {\n    name: receiptRaw.original_name,\n    type: receiptRaw.mime_type,\n  },\n};\n\n// Normalize integrations: bridge flat DB format \u2192 nested OCR format expected by extract handler\nconst intgRaw = profile.integrations || {};\nconst ocrProvider = intgRaw.ocr_provider || intgRaw['ocr.provider'] || 'google_vision';\nconst ocrApiKey   = intgRaw.ocr_api_key  || intgRaw['ocr.api_key']  || null;\n\nconst intgNormalized = {\n  ...intgRaw,\n  // Remove flat OCR keys\n  ocr_provider: undefined,\n  ocr_api_key:  undefined,\n  // Add nested OCR structure\n  ocr: {\n    provider: ocrProvider,\n    config:   ocrApiKey ? { api_key: ocrApiKey } : {},\n  },\n};\n\n// Remove undefined keys from integrations\nconst intgClean = Object.fromEntries(\n  Object.entries(intgNormalized).filter(([, v]) => v !== undefined)\n);\n\nconst customer_profile = {\n  customer_id:     receipt.customer_id,\n  modules_enabled: profile.modules_enabled || [],\n  integrations:    intgClean,\n  routing:         profile.routing || {},\n  custom:          profile.custom  || {},\n};\n\nreturn [{\n  json: {\n    module:           step.module,\n    required:         step.required,\n    receipt,\n    customer_profile,\n    trace_id:         trigger.trace_id || ('trc_' + Math.random().toString(36).slice(2, 12)),\n    idempotency_key:  'ik_' + step.module + '_' + receipt.receipt_id,\n  }\n}];\n"
      }
    }
