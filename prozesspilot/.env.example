# ══════════════════════════════════════════════════════════════════════════════
# ProzessPilot — Environment Variables (alphabetisch sortiert)
# Kopiere diese Datei als .env (lokal) oder .env.prod (Produktion)
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic / KI ────────────────────────────────────────────────────────────
# Claude API-Key fuer M04 Kategorisierung (alt: CLAUDE_API_KEY)
ANTHROPIC_API_KEY=sk-ant-...

# ── App / Allgemein ───────────────────────────────────────────────────────────
# Semantische Versionsnummer fuer /health Endpoint und Sentry-Releases
APP_VERSION=0.1.0

# ── AWS Backup ────────────────────────────────────────────────────────────────
# S3-Bucket fuer Off-Site DB-Backups (optional, nur wenn AWS statt MinIO)
AWS_BACKUP_BUCKET=prozesspilot-backups

# ── Backup-Konfiguration ─────────────────────────────────────────────────────
# Lokales Verzeichnis fuer pg_dump-Dumps
BACKUP_DIR=/backups
# Aufbewahrungsdauer in Tagen (Standard: 90)
RETENTION_DAYS=90

# ── Datenbank (Postgres 16) ───────────────────────────────────────────────────
# Passend zu docker-compose.yml Defaults
DATABASE_URL=postgres://pp:pp@localhost:5432/prozesspilot

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin-Passwort fuer Grafana-Dashboard
GRAFANA_ADMIN_PASSWORD=changeme

# ── Google Cloud Vision ───────────────────────────────────────────────────────
# Pfad zur Service-Account-JSON-Datei fuer M03 OCR
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-service-account.json
# Hartes Timeout fuer Vision-Calls (ms).
OCR_TIMEOUT_MS=15000

# ── Lexoffice ─────────────────────────────────────────────────────────────────
# Basis-URL der Lexoffice-API
LEXOFFICE_API_BASE=https://api.lexoffice.io/v1
# Timeout in Millisekunden fuer Lexoffice-API-Calls
LEXOFFICE_DEFAULT_TIMEOUT_MS=10000

# ── Node.js / Runtime ─────────────────────────────────────────────────────────
# Umgebung: development | test | production
NODE_ENV=development
# Log-Level: trace | debug | info | warn | error
LOG_LEVEL=debug
# Port des Fastify-Backends (Standard: 3000)
PORT=3000

# ── ProzessPilot Auth ─────────────────────────────────────────────────────────
# Dev-Bypass: PP_AUTH_DISABLED=1 deaktiviert HMAC-Pruefung (NIEMALS in Produktion!)
PP_AUTH_DISABLED=1
# HMAC-SHA256 Secret fuer API-Authentifizierung (min. 32 Zeichen)
# Erzeugen: openssl rand -hex 32
PP_HMAC_SECRET=<32-byte-hex>
PP_HMAC_TIMESTAMP_SKEW=300
# Verschluesselung Kundendaten (pgcrypto AES-256-GCM)
# Erzeugen: openssl rand -base64 32
PP_PGCRYPTO_KEY=<32-byte-base64>

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# S3-kompatibler Endpunkt (MinIO-URL oder AWS-S3-URL)
PP_S3_ENDPOINT=http://localhost:9000
# Name des S3-Buckets fuer Belege
PP_S3_BUCKET=prozesspilot-receipts
# Access Key fuer S3/MinIO
PP_S3_ACCESS_KEY=pp
# Secret Key fuer S3/MinIO
PP_S3_SECRET_KEY=pp-secret

# ── Sentry ────────────────────────────────────────────────────────────────────
# DSN fuer Fehler-Tracking (leer lassen um Sentry zu deaktivieren)
SENTRY_DSN=

# ── sevDesk ───────────────────────────────────────────────────────────────────
# Basis-URL der sevDesk-API
SEVDESK_API_BASE=https://my.sevdesk.de/api/v1
# Timeout in Millisekunden fuer sevDesk-API-Calls
SEVDESK_DEFAULT_TIMEOUT_MS=10000

# ── SMTP / E-Mail ─────────────────────────────────────────────────────────────
# SMTP-Host fuer ausgehende E-Mails (M07 Benachrichtigungen, M09 Kommunikation)
SMTP_FROM=ProzessPilot <noreply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PASS=smtp_password
# SMTP-Port (587 = STARTTLS, 465 = SSL/TLS)
SMTP_PORT=587
SMTP_USER=noreply@example.com

# ── Redis 7 ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO / S3-kompatibel (Legacy-Variablen fuer Kompatibilitaet) ─────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=pp
MINIO_SECRET_KEY=pp-secret
MINIO_BUCKET=prozesspilot-raw
STORAGE_RAW_BUCKET=prozesspilot-raw

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<sicheres-passwort>
# n8n braucht die Backend-Basis-URL (interner Docker-Hostname in Compose-Setup).
BACKEND_URL=http://backend:3000

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=pp-verify-token-changeme
WHATSAPP_GRAPH_API_VERSION=v19.0

# ── MS Graph / Excel OneDrive (M07 §9.3) ─────────────────────────────────────
# Azure AD App-Registration Client-ID (global fuer MS Graph Zugriff)
MSGRAPH_CLIENT_ID=<azure-app-client-id>
# Azure AD App-Registration Client-Secret
MSGRAPH_CLIENT_SECRET=<azure-app-client-secret>
# Standard-Tenant-ID (wird durch customer_credentials.meta.tenant_id ueberschrieben)
MSGRAPH_TENANT_ID=common

# ── Dropbox (M02 Archive) ─────────────────────────────────────────────────────
# Dropbox App-Key (aus Dropbox Developer Console)
DROPBOX_APP_KEY=<dropbox-app-key>
# Dropbox App-Secret
DROPBOX_APP_SECRET=<dropbox-app-secret>

# ── Legacy / Dev ──────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
GOOGLE_VISION_KEY_FILE=/secrets/gcp-vision.json
MINDEE_API_KEY=
DRIVE_FOLDER_CACHE_TTL_SEC=3600

# ── M14: Auth (Pflicht in Production) ─────────────────────────────────────────
# JWT-Signing-Secret — min 32 Zeichen, Production-Pflicht. Generieren:
#   openssl rand -hex 32
JWT_SECRET=
# Access-Token-Gültigkeit (Default 900 s = 15 min)
JWT_ACCESS_TTL_SECONDS=900
# Refresh-Token-Gültigkeit (Default 2592000 s = 30 Tage)
JWT_REFRESH_TTL_SECONDS=2592000
# argon2id-Parameter (Spec §7)
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1
# Lockout: 5 Failed Logins → 15 min gesperrt
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
# Refresh-Cookie (HttpOnly + Secure + SameSite=Strict empfohlen)
AUTH_REFRESH_COOKIE_NAME=pp_refresh
AUTH_REFRESH_COOKIE_SAMESITE=strict
# 1 = Secure-Flag setzen (HTTPS-Pflicht). Auf 0 nur für lokale http-Tests setzen.
AUTH_REFRESH_COOKIE_SECURE=1
# Bootstrap: erster super_admin per `npm run bootstrap:super-admin` anlegen.
# Werte unten sind nur Fallback für non-interaktiven CI-Bootstrap.
INITIAL_SUPER_ADMIN_EMAIL=
INITIAL_SUPER_ADMIN_PASSWORD=
