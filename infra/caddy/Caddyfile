# Gastro Reverse-Proxy-Konfiguration
# Liegt auf dem IONOS-Server unter /etc/caddy/Caddyfile
#
# Caddy übernimmt:
#   - TLS-Terminierung (Let's Encrypt, automatisch)
#   - HTTP → HTTPS-Redirect (automatisch)
#   - Reverse-Proxy zu Docker-Containern (localhost:8080-8084)
#   - Security-Header
#
# Subdomain-Routing:
#   admin.prozesspilot.net  → Mitarbeiter-Webapp        (Port 8081)
#   setup.prozesspilot.net  → Onboarding-Wizard         (Port 8082, T017)
#   api.prozesspilot.net    → Backend-API               (Port 8080)
#   chat.prozesspilot.net   → Web-Chat-Widget           (Port 8084, T072)

# Globale Optionen
{
	# Let's Encrypt-Account-Email (für Zertifikat-Ablauf-Benachrichtigungen)
	email steve@prozesspilot.net

	# Admin-API nur auf Localhost (Caddy-Default in v2, hier explizit)
	admin localhost:2019
}

# ── Mitarbeiter-Webapp ────────────────────────────────────────────────────────
admin.prozesspilot.net {
	encode gzip

	reverse_proxy localhost:8081

	header {
		# HSTS: 1 Jahr, includeSubDomains + preload
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		# Keine Iframe-Einbettung (Mitarbeiter-Tool, kein Widget)
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# CSP: lädt nur eigene Assets + Backend-API
		# wss://api.prozesspilot.net ist vorbereitet für späteres Live-Update-Feature
		# (z.B. neue-Belege-Push) — aktuell gibt es noch keinen WebSocket-Endpoint.
		Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; connect-src 'self' https://api.prozesspilot.net wss://api.prozesspilot.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
		# Permissions-Policy: keine unnötigen Browser-Features
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# ── Onboarding-Wizard (Wirt-Setup, einmalig) ─────────────────────────────────
# T017: onboarding-wizard-Container (nginx) statt Stub. nginx proxyt /api/ intern
# an backend:3000 → der Browser spricht nur mit setup.* (connect-src 'self').
setup.prozesspilot.net {
	encode gzip

	reverse_proxy localhost:8082

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		# Vollseiten-Wizard, kein eingebettetes Widget → DENY.
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# CSP: eigene Assets + same-origin /api (von nginx ans Backend geproxyt) +
		# Google-Fonts (Poppins/Manrope/JetBrains Mono aus index.html).
		Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; connect-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# ── Backend-API ───────────────────────────────────────────────────────────────
api.prozesspilot.net {
	encode gzip

	reverse_proxy localhost:8080

	# API-spezifische Header (kein X-Frame, kein CSP — API liefert nur JSON)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		# Referrer-Policy + Permissions-Policy auch für API-Subdomain:
		# Caddy-Default-Error-Pages sind HTML und können sonst Referrer leaken.
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# CORS wird vom Backend selbst gesetzt (Fastify-cors-Plugin)
	}

	# Body-Limit für Multipart-Upload (Belege max. 20 MB, 25 MB Puffer)
	request_body {
		max_size 25MB
	}
}

# ── Web-Chat-Widget (Customer-facing) ────────────────────────────────────────
# T072: web-chat-widget-Container (nginx) statt Stub. nginx proxyt /api/ intern an
# backend:3000 (inkl. SSE) → der Browser spricht nur mit chat.* (CSP connect-src
# 'self'). Gelockte Entscheidung (2026-06-24): EIGENE Seite, kein Cross-Origin-
# Iframe-Embed im Pilot → X-Frame-Options DENY. (Same-origin-Embed auf
# prozesspilot.net = Folge; dann frame-ancestors statt DENY.)
chat.prozesspilot.net {
	encode gzip

	reverse_proxy localhost:8084

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		# Vollseiten-Widget, kein eingebettetes Iframe → DENY.
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# CSP: eigene Assets + same-origin /api (von nginx ans Backend geproxyt) +
		# Google-Fonts (Poppins/Manrope/JetBrains Mono aus index.html).
		Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; connect-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}
