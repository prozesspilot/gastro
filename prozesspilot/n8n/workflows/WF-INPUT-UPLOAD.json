                },
                "conditions": [
                  {
                    "leftValue": "={{$json.module}}",
                    "rightValue": "M07",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "outputKey": "M07"
            }
          ]
